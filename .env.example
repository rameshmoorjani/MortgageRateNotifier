# Mortgage Rate Notifier Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# OpenAI Configuration (REQUIRED)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ============================================================================
# Mortgage Rates API Configuration
# ============================================================================
# Get your free FRED API key from: https://stlouisfed.org/apps/fred/
# This provides real Federal Reserve mortgage rate data
FRED_API_KEY=your-fred-api-key-here

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ============================================================================
# Environment Settings
# ============================================================================
ENVIRONMENT=development
# Options: development, production, staging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Orchestration Settings
# ============================================================================
NOTIFICATION_STRATEGY=ALWAYS
# Options: ALWAYS, ON_SIGNIFICANT_CHANGE, CRITICAL_ONLY, NEVER

# ============================================================================
# Database Settings (Optional - for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/mortgage_notifier
# REDIS_URL=redis://localhost:6379

# ============================================================================
# Email Configuration (Optional - for notifications)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=your-email@example.com

# ============================================================================
# Monitoring & Logging (Optional)
# ============================================================================
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# PROMETHEUS_ENABLED=false

# ============================================================================
# Rate Limiting (Optional - for future use)
# ============================================================================
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================================================
# Docker Settings (If using docker-compose)
# ============================================================================
# DOCKER_NETWORK=mortgage-network
# DOCKER_RESTART_POLICY=unless-stopped
